@model MotorcyclePartShop.Models.Product
@{
    ViewData["Title"] = Model.ProductName;
    var relatedProducts = ViewBag.RelatedProducts as List<MotorcyclePartShop.Models.Product>;

    // Calculate discount price (if any)
    var promo = Model.PromotionProducts.FirstOrDefault()?.Promotion;
    double discount = (promo != null && promo.IsActive && promo.EndDate >= DateTime.Now) ? promo.DiscountPercent : 0;
    decimal finalPrice = Model.Price * (decimal)(1 - discount / 100);
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-dark">Home</a></li>
            <li class="breadcrumb-item"><a href="/Product" class="text-decoration-none text-dark">Products</a></li>
            <li class="breadcrumb-item active text-truncate" style="max-width: 300px;" aria-current="page">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="row bg-white shadow-sm p-3 mb-4 rounded">
        <div class="col-md-5 mb-4 mb-md-0">
            <div class="border rounded p-2 text-center">
                <img src="@(Model.MainImage.StartsWith("http") ? Model.MainImage : "/images/products/" + Model.MainImage)"
                     class="img-fluid" style="max-height: 400px;" alt="@Model.ProductName">
            </div>
        </div>

        <div class="col-md-7">
            <h3 class="fw-bold mb-3">@Model.ProductName</h3>

            <div class="d-flex align-items-center mb-3">
                <span class="text-muted small me-3">Brand: <a href="/Product?brandId=@Model.Brand?.BrandId" class="text-danger fw-bold text-decoration-none">@Model.Brand?.BrandName</a></span>
                <span class="text-muted small">
                    Availability:
                    @if (Model.Stock > 0)
                    {
                        <span class="text-success fw-bold"><i class="fas fa-check-circle"></i> In Stock</span>
                    }
                    else
                    {
                        <span class="text-secondary fw-bold">Out of Stock</span>
                    }
                </span>
            </div>

            <div class="p-3 bg-light rounded mb-4">
                @if (discount > 0)
                {
                    <div class="d-flex align-items-baseline">
                        <span class="text-dark fw-bold me-2" style="font-size: 16px;">Price:</span>

                        <div class="d-flex flex-column">
                            <span class="text-danger fw-bold lh-1" style="font-size: 28px;">
                                @finalPrice.ToString("#,##0")<u style="text-decoration: underline; font-size: 20px; vertical-align: top;">đ</u>
                            </span>
                            <div class="mt-1">
                                <span class="text-decoration-line-through text-muted me-2">@Model.Price.ToString("#,##0")đ</span>
                                <span class="badge bg-danger">Price -@discount% (after aplly coupon)</span>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center">
                        <span class="text-dark fw-bold me-2" style="font-size: 16px;">Price:</span>
                        <span class="text-danger fw-bold" style="font-size: 28px;">
                            @Model.Price.ToString("#,##0")<u style="text-decoration: underline; font-size: 20px; vertical-align: top; margin-left: 2px;">đ</u>
                        </span>
                    </div>
                }
            </div>

            @if (Model.Stock > 0)
            {
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-danger flex-grow-1 py-2 fw-bold" onclick="addToCart(@Model.ProductId)">
                            <i class="fas fa-cart-plus me-2"></i> ADD TO CART
                        </button>

                        <a href="/Cart/AddToCart/@Model.ProductId" class="btn btn-danger flex-grow-1 py-2 fw-bold text-uppercase d-flex flex-column align-items-center justify-content-center text-decoration-none">
                            <span>BUY NOW</span>
                            <small class="fw-normal" style="font-size: 11px;">Home Delivery</small>
                        </a>
                    </div>
                </div>
            }
            else
            {
                <button class="btn btn-secondary w-100" disabled>TEMPORARILY OUT OF STOCK</button>
            }

            <div class="mt-4 border-top pt-3">
                <ul class="list-unstyled small text-secondary">
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> 100% Genuine Product Commitment</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Warranty per manufacturer standards</li>
                    <li class="mb-2"><i class="fas fa-shipping-fast text-success me-2"></i> Nationwide Delivery</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom-0">
                    <ul class="nav nav-tabs card-header-tabs" id="productTabs" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active fw-bold text-dark" id="desc-tab" data-bs-toggle="tab" data-bs-target="#desc" type="button">Product Description</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link fw-bold text-dark" id="spec-tab" data-bs-toggle="tab" data-bs-target="#spec" type="button">Technical Specifications</button>
                        </li>
                    </ul>
                </div>
                <div class="card-body">
                    <div class="tab-content" id="productTabsContent">
                        <div class="tab-pane fade show active" id="desc" role="tabpanel">
                            <div style="white-space: pre-line;">
                                @Html.Raw(Model.Description ?? "Content updating...")
                            </div>
                        </div>

                        <div class="tab-pane fade" id="spec" role="tabpanel">
                            @if (Model.Specifications != null && Model.Specifications.Any())
                            {
                                <table class="table table-striped table-bordered">
                                    <tbody>
                                        @foreach (var spec in Model.Specifications)
                                        {
                                            <tr>
                                                <th class="w-25">@spec.SpecName</th>
                                                <td>@spec.SpecValue</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <p class="text-muted">No specifications available.</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (relatedProducts != null && relatedProducts.Any())
    {
        <div class="mb-4">
            <h4 class="text-uppercase fw-bold border-bottom border-danger pb-2 mb-3">Related Products</h4>
            <div class="row row-cols-2 row-cols-md-4 g-3">
                @foreach (var item in relatedProducts)
                {
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm product-card">
                            <div class="position-relative p-2" style="height: 180px; overflow: hidden;">
                                <img src="@(item.MainImage.StartsWith("http") ? item.MainImage : "/images/products/" + item.MainImage)"
                                     class="card-img-top h-100 w-100" style="object-fit: contain;">
                            </div>
                            <div class="card-body text-center">
                                <h6 class="card-title text-truncate">
                                    <a href="/Product/Details/@item.ProductId" class="text-decoration-none text-dark">@item.ProductName</a>
                                </h6>
                                <div class="text-danger fw-bold">@item.Price.ToString("#,##0")₫</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    .nav-tabs .nav-link.active {
        border-top: 3px solid #d70018;
        color: #d70018 !important;
    }

    .product-card:hover {
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        transition: 0.3s;
    }
</style>

@section Scripts {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        // Cấu hình Toastr
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right", // <--- SỬA DÒNG NÀY (Góc trên phải)
            "timeOut": "3000"
        };

        function addToCart(productId) {
            $.ajax({
                url: '/Cart/AddToCart/' + productId,
                type: 'GET',
                success: function (response) {
                    if (response.success) {
                        // 1. Show Toastr Notification (Green Success)
                        toastr.success('Added to cart successfully!', 'Success');

                        // 2. Update Cart Count
                        if (response.count > 0) {
                            $('#cartCountBadge').text(response.count);
                            $('#cartCountBadge').removeClass('d-none');
                        }
                    } else {
                        // Show Error Toastr (Red)
                        toastr.error(response.message || 'Error adding product.', 'Failed');
                    }
                },
                error: function () {
                    toastr.error('Error communicating with server.', 'System Error');
                }
            });
        }
    </script>
}