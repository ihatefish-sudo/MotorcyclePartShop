@model List<MotorcyclePartShop.Models.Product>
@{
    ViewData["Title"] = "Compare Vehicles";
    // Get list of specs from Controller
    var specNames = ViewBag.SpecNames as List<string>;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-uppercase text-secondary">
            <i class=" text-danger me-2"></i> Compare Vehicles
        </h2>

        <div class="position-relative" style="width: 400px;">
            <div class="input-group">
                <input type="text" id="compareSearchInput" class="form-control" placeholder="Search product name to add..." autocomplete="off">

                @if (Model != null && Model.Any())
                {
                    <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#confirmClearModal" title="Clear All">
                        <i class="fas fa-undo"></i>
                    </button>
                }
            </div>
            <div id="compareSearchSuggestions" class="list-group position-absolute w-100 shadow" style="top: 100%; z-index: 1000; display:none;"></div>
        </div>
    </div>

    <div id="compareContent">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive shadow-sm rounded">
                <table class="table table-bordered table-striped align-middle text-center mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th style="width: 200px;" class="align-middle">Specifications</th>
                            @foreach (var product in Model)
                            {
                                <th style="min-width: 250px;" class="position-relative bg-white text-dark border-bottom-0 p-3">
                                    <button class="btn btn-sm btn-outline-danger position-absolute top-0 end-0 m-2 border-0 rounded-circle"
                                            onclick="removeProduct(@product.ProductId)" title="Remove">
                                        <i class="fas fa-times"></i>
                                    </button>

                                    <img src="@(product.MainImage != null && product.MainImage.StartsWith("http") ? product.MainImage : "/images/products/" + product.MainImage)"
                                         style="height: 120px; object-fit: contain;" class="mb-2">
                                    <h6 class="fw-bold text-uppercase text-black mb-1">@product.ProductName</h6>
                                    <div class="text-danger fw-bold fs-5">@product.Price.ToString("#,##0")₫</div>
                                    <a href="/Product/Details/@product.ProductId" class="btn btn-sm btn-outline-danger mt-2 rounded-pill px-3">View Details</a>
                                </th>
                            }

                            @* Empty Columns *@
                            @for (int i = 0; i < (3 - Model.Count); i++)
                            {
                                <th class="bg-light text-muted fw-normal align-middle" style="min-width: 250px;">
                                    <div style="height: 120px; display: flex; align-items: center; justify-content: center; background: #f8f9fa; border-radius: 8px; margin-bottom: 10px; border: 2px dashed #dee2e6;">
                                        <i class="fas fa-plus fa-2x text-secondary opacity-25"></i>
                                    </div>
                                    <p class="small text-muted mb-0">Add item to compare</p>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (specNames != null && specNames.Any())
                        {
                            foreach (var spec in specNames)
                            {
                                <tr>
                                    <td class="fw-bold text-start bg-light ps-4 text-secondary">@spec</td>
                                    @foreach (var product in Model)
                                    {
                                        string val = "-";
                                        if (product.Specifications != null)
                                        {
                                            var specItem = product.Specifications.FirstOrDefault(s => s.SpecName == spec);
                                            if (specItem != null) { val = specItem.SpecValue; }
                                        }
                                        <td>@val</td>
                                    }
                                    @for (int i = 0; i < (3 - Model.Count); i++)
                                    {
                                        <td></td>
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@(Model.Count + 1)" class="text-center py-4 text-muted">
                                    Specifications not configured.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 bg-white rounded shadow-sm border border-dashed">
                <i class="fas fa-motorcycle fa-4x text-muted mb-3 opacity-50"></i>
                <h4 class="fw-bold text-secondary">Compare List is Empty</h4>
                <p class="text-muted">Search and add vehicles to see the differences.</p>
                <a href="/Product" class="btn btn-primary px-4 rounded-pill">Browse Shop</a>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="confirmClearModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold"><i class="fas fa-exclamation-triangle me-2"></i> Confirm Action</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <p class="mb-0 fs-5">Are you sure you want to <strong class="text-danger">clear</strong> the entire comparison list?</p>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger px-4" onclick="executeClearAll()">Yes, Clear All</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        const COMPARE_KEY = 'moto_compare_ids';

        $(document).ready(function() {
            // Configure Toastr: Top Right
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "timeOut": "3000"
            };

            syncLocalStorageToUrl();
            updateNavCount();

            let timeout = null;

            // Live Search
            $('#compareSearchInput').on('keyup', function() {
                let query = $(this).val();
                clearTimeout(timeout);

                if (query.length < 2) {
                    $('#compareSearchSuggestions').hide();
                    return;
                }

                timeout = setTimeout(function() {
                    $.get('/Product/SearchMotorcycleJson', { query: query }, function(data) {
                        let html = '';
                        if (data.length > 0) {
                            data.forEach(p => {
                                let imgUrl = p.image && p.image.startsWith('http') ? p.image : '/images/products/' + p.image;
                                let price = new Intl.NumberFormat('en-US').format(p.price);

                                html += `
                                    <button class="list-group-item list-group-item-action d-flex align-items-center p-2" onclick="addProductToCompare(${p.id})">
                                        <img src="${imgUrl}" style="width: 50px; height: 50px; object-fit: contain;" class="me-3 rounded border">
                                        <div>
                                            <div class="fw-bold text-dark">${p.name}</div>
                                            <div class="text-danger small fw-bold">${price}₫</div>
                                        </div>
                                    </button>
                                `;
                            });
                        } else {
                            html = '<div class="list-group-item text-muted small text-center py-3">No products found.</div>';
                        }
                        $('#compareSearchSuggestions').html(html).show();
                    });
                }, 300);
            });

            $(document).click(function(e) {
                if (!$(e.target).closest('#compareSearchInput, #compareSearchSuggestions').length) {
                    $('#compareSearchSuggestions').hide();
                }
            });
        });

        // --- CORE LOGIC ---

        function syncLocalStorageToUrl() {
            let currentIds = JSON.parse(localStorage.getItem(COMPARE_KEY)) || [];
            let urlParams = new URLSearchParams(window.location.search);
            let urlIds = urlParams.get('ids');

            if (currentIds.length > 0 && !urlIds) {
                window.location.href = `/Product/Compare?ids=${currentIds.join(',')}`;
            }
            if (urlIds && currentIds.length === 0) {
                let idsFromUrl = urlIds.split(',').map(Number);
                localStorage.setItem(COMPARE_KEY, JSON.stringify(idsFromUrl));
            }
        }

        // Action when Modal "Yes" is clicked
        function executeClearAll() {
            localStorage.removeItem(COMPARE_KEY);
            // Optional: Show toast before redirect (might be too fast to see)
            // toastr.success('All items cleared.');
            window.location.href = '/Product/Compare';
        }

        function addProductToCompare(id) {
            let currentIds = JSON.parse(localStorage.getItem(COMPARE_KEY)) || [];

            // Updated: Use Toastr for Warnings
            if (currentIds.includes(id)) {
                toastr.warning('This product is already in the comparison list!');
                $('#compareSearchInput').val('');
                $('#compareSearchSuggestions').hide();
                return;
            }

            if (currentIds.length >= 3) {
                toastr.error('Limit reached: You can compare up to 3 products.');
                $('#compareSearchSuggestions').hide();
                return;
            }

            currentIds.push(id);
            localStorage.setItem(COMPARE_KEY, JSON.stringify(currentIds));
            // Reload page to update UI
            reloadPage(currentIds);
        }

        function removeProduct(id) {
            let currentIds = JSON.parse(localStorage.getItem(COMPARE_KEY)) || [];
            currentIds = currentIds.filter(item => item !== id);
            localStorage.setItem(COMPARE_KEY, JSON.stringify(currentIds));
            reloadPage(currentIds);
        }

        function reloadPage(ids) {
            if (ids.length > 0) {
                window.location.href = `/Product/Compare?ids=${ids.join(',')}`;
            } else {
                window.location.href = `/Product/Compare`;
            }
        }

        function updateNavCount() {
            let currentIds = JSON.parse(localStorage.getItem(COMPARE_KEY)) || [];
            let badge = $('#navCompareCount');
            if (badge.length) {
                if (currentIds.length > 0) {
                    badge.text(currentIds.length).show();
                } else {
                    badge.hide();
                }
            }
        }
    </script>
}