@model List<MotorcyclePartShop.Models.CartItem>

@{
    ViewData["Title"] = "Your Cart";
    decimal totalAmount = ViewBag.CartTotal ?? 0;
}

<div class="container py-5">
    <div class="row">
        <div class="col-12 mb-4">
            <h3 class="fw-bold text-uppercase border-bottom border-danger pb-2">
                <i class="fas fa-shopping-cart text-danger me-2"></i> Shopping Cart (@Model.Count items)
            </h3>
        </div>

        @if (Model.Count > 0)
        {
            <div class="col-lg-8">
                <div class="table-responsive">
                    <table class="table table-hover align-middle border">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 100px;">Product</th>
                                <th>Name</th>
                                <th>Unit Price</th>
                                <th style="width: 120px;">Quantity</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <img src="@(item.MainImage.StartsWith("http") ? item.MainImage : "/images/products/" + item.MainImage)"
                                             class="img-fluid rounded border"
                                             style="width: 80px; height: 80px; object-fit: cover;"
                                             alt="@item.ProductName">
                                    </td>
                                    <td>
                                        <a href="/Product/Details/@item.ProductId" class="text-decoration-none text-dark fw-bold">
                                            @item.ProductName
                                        </a>
                                    </td>
                                    <td class="text-danger fw-bold">@item.Price.ToString("#,##0")₫</td>
                                    <td>
                                        <form action="/Cart/UpdateCart" method="post" class="d-flex">
                                            <input type="hidden" name="id" value="@item.ProductId" />
                                            <input type="number" name="quantity" value="@item.Quantity" min="1"
                                                   class="form-control form-control-sm text-center"
                                                   onchange="this.form.submit()" />
                                        </form>
                                    </td>
                                    <td class="fw-bold">@item.Total.ToString("#,##0")₫</td>
                                    <td class="text-end">
                                        <button type="button"
                                                class="btn btn-link text-secondary fs-5 p-0 border-0"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-url="/Cart/Remove/@item.ProductId"
                                                title="Remove Item">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between mt-3">
                    <a href="/Product" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i> Continue Shopping
                    </a>

                    <button type="button"
                            class="btn btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal"
                            data-url="/Cart/Clear"
                            data-message="Are you sure you want to empty your entire cart?">
                        <i class="fas fa-trash me-2"></i> Clear Cart
                    </button>
                </div>
            </div>

            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Cart Summary</h5>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Subtotal:</span>
                            <span class="fw-bold">@totalAmount.ToString("#,##0")₫</span>
                        </div>
@*                         <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                            <span class="text-muted">Shipping Fee:</span>
                            <span class="text-success">Free</span>
                        </div> *@
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold fs-5">Total:</span>
                            <span class="fw-bold fs-4 text-danger">@totalAmount.ToString("#,##0")₫</span>
                        </div>

                        @if (Context.Session.GetString("UserId") == null)
                        {
                            <div class="alert alert-warning small">
                                <i class="fas fa-info-circle"></i> Please <a href="/Auth/Login" class="fw-bold">Login</a> to checkout.
                            </div>
                            <a href="/Auth/Login" class="btn btn-dark w-100 py-2">LOGIN TO CHECKOUT</a>
                        }
                        else
                        {
                            <a href="/Order/Checkout" class="btn btn-danger w-100 py-2 fw-bold text-uppercase">
                                PROCEED TO CHECKOUT
                            </a>
                        }
                    </div>
                </div>
                <div class="mt-3 text-center small text-muted">
                    <i class="fas fa-shield-alt text-success me-1"></i> 100% Secure Payment
                </div>
            </div>
        }
        else
        {
            <div class="col-12 text-center py-5">
                <img src="https://cdn-icons-png.flaticon.com/512/2038/2038854.png" alt="Empty Cart" style="width: 150px; opacity: 0.5;">
                <h4 class="mt-4 text-muted">Your cart is empty!</h4>
                <p class="mb-4 text-secondary">Please select some products to shop.</p>
                <a href="/Product" class="btn btn-danger px-4 py-2">
                    <i class="fas fa-shopping-cart me-2"></i> Shop Now
                </a>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white border-bottom-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-exclamation-circle me-2"></i> Confirmation
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4 text-center">
                <p class="mb-0 fs-5" id="deleteMessage">Are you sure you want to remove this item?</p>
                <p class="text-muted small mt-2 mb-0">This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-top-0 justify-content-center pb-4">
                <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Cancel</button>
                <a href="#" id="confirmDeleteBtn" class="btn btn-danger px-4 fw-bold">Yes, Remove</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var deleteModal = document.getElementById('deleteModal');
        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var url = button.getAttribute('data-url');
                var message = button.getAttribute('data-message');

                var confirmBtn = deleteModal.querySelector('#confirmDeleteBtn');
                confirmBtn.href = url;

                var messageEl = deleteModal.querySelector('#deleteMessage');
                if (message) {
                    messageEl.textContent = message;
                } else {
                    messageEl.textContent = "Are you sure you want to remove this item?";
                }
            });
        }
    </script>
}