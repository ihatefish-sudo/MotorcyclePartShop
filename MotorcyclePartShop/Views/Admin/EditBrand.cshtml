@model MotorcyclePartShop.Models.Brand

@{
    ViewData["Title"] = "Edit Brand";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0" style="max-width: 600px; margin: 0 auto;">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0 fw-bold"><i class="fas fa-edit me-2"></i> Edit Brand</h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="EditBrand" method="post">
            <input type="hidden" asp-for="BrandId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label class="form-label fw-bold">Brand Name <span class="text-danger">*</span></label>
                <input asp-for="BrandName" class="form-control" required />
                <span asp-validation-for="BrandName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-4 form-check form-switch">
                <input class="form-check-input" type="checkbox" asp-for="IsActive">
                <label class="form-check-label" asp-for="IsActive">Active</label>
            </div>

            <div class="d-flex justify-content-between">
                <a href="/Admin/Brands" class="btn btn-secondary px-4">Cancel</a>
                <button type="submit" class="btn btn-primary fw-bold px-4">Save Changes</button>
            </div>
        </form>
    </div>
</div>