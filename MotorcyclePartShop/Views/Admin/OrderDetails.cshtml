@model MotorcyclePartShop.Models.Order
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Order Details";

    // Biến kiểm tra trạng thái để khóa
    bool isDeliveryLocked = Model.DeliveryStatus == "Completed";
    bool isPaymentLocked = Model.PaymentStatus == "Paid";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-secondary">
            <a href="/Admin/Orders" class="text-decoration-none text-muted"><i class="fas fa-arrow-left"></i></a>
            Order Details: <span class="text-danger">#@Model.TrackingCode</span>
        </h4>
        <span class="text-muted"><i class="far fa-clock"></i> Order Date: @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-danger text-white fw-bold">
                    <i class=" me-2"></i> Product List
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0 table-hover">
                        <thead class="bg-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-center">Image</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Price</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <span class="fw-bold">@item.Product.ProductName</span>
                                    </td>
                                    <td class="text-center">
                                        <img src="@(item.Product.MainImage.StartsWith("http") ? item.Product.MainImage : "/images/products/" + item.Product.MainImage)"
                                             style="width: 50px; height: 50px; object-fit: cover;" class="rounded border">
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.Price.ToString("#,##0")₫</td>
                                    <td class="text-end fw-bold text-danger">@((item.Price * item.Quantity).ToString("#,##0"))₫</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-light">
                            <tr>
                                <td colspan="4" class="text-end fw-bold">Grand Total:</td>
                                <td class="text-end fw-bold text-danger fs-5">@Model.TotalAmount.ToString("#,##0")₫</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">

            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class=" me-2"></i> Customer Info
                </div>
                <div class="card-body">
                    <p class="mb-2"><strong>Name:</strong> @(Model.User?.FullName ?? "Unknown")</p>
                    <p class="mb-2"><strong>Phone:</strong> @(Model.User?.Phone ?? "N/A")</p>
                    <p class="mb-2"><strong>Email:</strong> @(Model.User?.Email ?? "N/A")</p>
                    <hr>
                    <p class="mb-0 small text-muted">
                        <strong>Shipping Address:</strong><br>
                        @Model.ShippingAddress
                    </p>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class=" me-2"></i> Update Status
                </div>
                <div class="card-body">
                    <form action="/Admin/UpdateOrderStatus" method="post">
                        <input type="hidden" name="OrderId" value="@Model.OrderId" />

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">DELIVERY STATUS</label>
                            @if (isDeliveryLocked)
                            {
                                <div class="alert alert-success py-2 mb-1 small">
                                    <i class="fas fa-check-circle"></i> Completed (Locked)
                                </div>
                                <input type="hidden" name="DeliveryStatus" value="Completed" />
                                <select class="form-select bg-light" disabled>
                                    <option>Completed</option>
                                </select>
                            }
                            else
                            {
                                <select name="DeliveryStatus" class="form-select">
                                    <!option value="Pending" @(Model.DeliveryStatus == "Pending" ? "selected" : "")>Pending</!option>
                                    <!option value="Shipping" @(Model.DeliveryStatus == "Shipping" ? "selected" : "")>Shipping</!option>
                                    <!option value="Completed" @(Model.DeliveryStatus == "Completed" ? "selected" : "")>Completed</!option>
                                    <!option value="Returned" @(Model.DeliveryStatus == "Returned" ? "selected" : "")>Returned</!option>
                                    <!option value="Cancelled" @(Model.DeliveryStatus == "Cancelled" ? "selected" : "")>Cancelled</!option>
                                </select>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">PAYMENT STATUS</label>
                            @if (isPaymentLocked)
                            {
                                <div class="alert alert-success py-2 mb-1 small">
                                    <i class="fas fa-check-circle"></i> Paid (Locked)
                                </div>
                                <input type="hidden" name="PaymentStatus" value="Paid" />
                                <select class="form-select bg-light" disabled>
                                    <option>Paid</option>
                                </select>
                            }
                            else
                            {
                                <select name="PaymentStatus" class="form-select">
                                    <!option value="Pending" @(Model.PaymentStatus == "Pending" ? "selected" : "")>Pending (Unpaid)</!option>
                                    <!option value="Paid" @(Model.PaymentStatus == "Paid" ? "selected" : "")>Paid</!option>
                                    <!option value="Refunded" @(Model.PaymentStatus == "Refunded" ? "selected" : "")>Refunded</!option>
                                </select>
                            }
                        </div>

                        @if (isDeliveryLocked && isPaymentLocked)
                        {
                            <button type="button" class="btn btn-secondary w-100" disabled>All Statuses Locked</button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-primary w-100 fw-bold">
                                <i class=" me-2"></i> Save Changes
                            </button>
                        }
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "3000"
        };

        $(document).ready(function () {
            var successMsg = '@TempData["Success"]';
            var errorMsg = '@TempData["Error"]';

            if (successMsg) {
                toastr.success(successMsg, 'Success');
            }
            if (errorMsg) {
                toastr.error(errorMsg, 'Error');
            }
        });
    </script>
}