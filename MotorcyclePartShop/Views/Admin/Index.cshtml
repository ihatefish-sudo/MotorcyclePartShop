@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard Overview";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-danger"> DASHBOARD OVERVIEW</h3>
    <span class="text-muted small">Last updated: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-0 border-start border-4 border-primary h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold">Total Orders</h6>
                        <h2 class="fw-bold text-primary mb-0">@ViewBag.TotalOrders</h2>
                    </div>
                    <div class="icon-box bg-primary bg-opacity-10 text-primary rounded p-3">
                        <i class="fas fa-shopping-bag fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 border-start border-4 border-success h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold">Total Revenue</h6>
                        <h2 class="fw-bold text-success mb-0">@ViewBag.TotalRevenue.ToString("#,##0")₫</h2>
                    </div>
                    <div class="icon-box bg-success bg-opacity-10 text-success rounded p-3">
                        <i class="fas fa-money-bill-wave fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 border-start border-4 border-warning h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold">Products</h6>
                        <h2 class="fw-bold text-warning mb-0">@ViewBag.TotalProducts</h2>
                    </div>
                    <div class="icon-box bg-warning bg-opacity-10 text-warning rounded p-3">
                        <i class="fas fa-box fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 border-start border-4 border-info h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold">Customers</h6>
                        <h2 class="fw-bold text-info mb-0">@ViewBag.TotalUsers</h2>
                    </div>
                    <div class="icon-box bg-info bg-opacity-10 text-info rounded p-3">
                        <i class="fas fa-users fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body bg-light">
        <div class="row text-center divide-cols">
            <div class="col-md-4">
                <small class="text-muted text-uppercase fw-bold">Today</small>
                <h4 class="fw-bold text-dark mt-1">@ViewBag.RevenueToday.ToString("#,##0")₫</h4>
            </div>
            <div class="col-md-4 border-start border-end">
                <small class="text-muted text-uppercase fw-bold">This Week</small>
                <h4 class="fw-bold text-dark mt-1">@ViewBag.RevenueWeek.ToString("#,##0")₫</h4>
            </div>
            <div class="col-md-4">
                <small class="text-muted text-uppercase fw-bold">This Month</small>
                <h4 class="fw-bold text-dark mt-1">@ViewBag.RevenueMonth.ToString("#,##0")₫</h4>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3 border-bottom">
                <h6 class="m-0 fw-bold text-danger"><i class="fas fa-chart-bar me-2"></i> Monthly Revenue</h6>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white py-3 border-bottom">
                <h6 class="m-0 fw-bold text-primary"><i class="fas fa-chart-pie me-2"></i> Order Status</h6>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <div style="width: 100%; max-width: 250px;">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-success text-white">
                <h6 class="m-0 fw-bold"><i class="fas fa-trophy me-2"></i> Top 5 Best Selling</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-3">Product</th>
                                <th class="text-center">Sold</th>
                                <th class="text-end pe-3">Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var topProducts = ViewBag.TopProducts as dynamic;
                            }
                            @if (topProducts != null)
                            {
                                foreach (var item in topProducts)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <div class="d-flex align-items-center">
                                                <img src="@(item.Image.StartsWith("http") ? item.Image : "/images/products/" + item.Image)"
                                                     class="rounded border me-2" width="40" height="40" style="object-fit:cover;">
                                                <span class="fw-bold small text-dark text-truncate" style="max-width: 200px;">@item.Name</span>
                                            </div>
                                        </td>
                                        <td class="text-center fw-bold text-success">@item.TotalSold</td>
                                        <td class="text-end pe-3 small">@item.TotalRevenue.ToString("#,##0")₫</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-warning text-dark">
                <h6 class="m-0 fw-bold"><i class="fas fa-exclamation-triangle me-2"></i> Top 5 Least Selling</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-3">Product</th>
                                <th class="text-center">Sold</th>
                                <th class="text-end pe-3">Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var bottomProducts = ViewBag.BottomProducts as dynamic;
                            }
                            @if (bottomProducts != null)
                            {
                                foreach (var item in bottomProducts)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <div class="d-flex align-items-center">
                                                <img src="@(item.Image.StartsWith("http") ? item.Image : "/images/products/" + item.Image)"
                                                     class="rounded border me-2" width="40" height="40" style="object-fit:cover;">
                                                <span class="fw-bold small text-dark text-truncate" style="max-width: 200px;">@item.Name</span>
                                            </div>
                                        </td>
                                        <td class="text-center fw-bold text-warning">@item.TotalSold</td>
                                        <td class="text-end pe-3 small">@item.TotalRevenue.ToString("#,##0")₫</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // --- 1. REVENUE CHART ---
        var revenueData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RevenueChartData));
        var ctxRev = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctxRev, {
            type: 'bar',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                datasets: [{
                    label: 'Revenue (VND)',
                    data: revenueData,
                    backgroundColor: 'rgba(215, 0, 24, 0.7)',
                    borderColor: 'rgba(215, 0, 24, 1)',
                    borderWidth: 1,
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { callback: function(value) { return value.toLocaleString('vi-VN', {style : 'currency', currency : 'VND'}); } }
                    }
                },
                plugins: { legend: { display: false } }
            }
        });

        // --- 2. STATUS CHART (UPDATED: FIXED COLORS) ---
        var statusLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusLabels));
        var statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusData));

        // Định nghĩa màu cố định cho từng trạng thái
        const statusColorMap = {
            'Pending': '#ffc107',   // Vàng
            'Shipping': '#0dcaf0',  // Xanh dương nhạt
            'Completed': '#198754', // Xanh lá cây (Quan trọng)
            'Cancelled': '#dc3545', // Đỏ
            'Returned': '#6c757d'   // Xám
        };

        // Map màu dựa trên Label thực tế trả về từ Server
        const backgroundColors = statusLabels.map(label => statusColorMap[label] || '#cccccc');

        var ctxStatus = document.getElementById('statusChart').getContext('2d');
        new Chart(ctxStatus, {
            type: 'doughnut',
            data: {
                labels: statusLabels,
                datasets: [{
                    data: statusData,
                    backgroundColor: backgroundColors, // Sử dụng mảng màu động đã map
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });
    </script>
}