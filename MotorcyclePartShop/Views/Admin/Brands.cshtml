@model IEnumerable<MotorcyclePartShop.Models.Brand>

@{
    ViewData["Title"] = "Brand Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">BRAND MANAGEMENT</h5>
        <a href="/Admin/CreateBrand" class="btn btn-sm btn-light text-danger fw-bold shadow-sm">
            <i class="fas fa-plus-circle me-1"></i> Add Brand
        </a>
    </div>

    <div class="card-body bg-light border-bottom">
        <form action="/Admin/Brands" method="get" class="row g-2 align-items-center">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="search" class="form-control border-start-0 ps-0"
                           placeholder="Search Brand Name..." value="@ViewBag.CurrentSearch">
                </div>
            </div>
            <div class="col-md-4">
                <select name="status" class="form-select" onchange="this.form.submit()">
                    <option value="">-- All Status --</option>
                    <!option value="active" @(ViewBag.CurrentStatus == "active" ? "selected" : "")>Active</!option>
                    <!option value="inactive" @(ViewBag.CurrentStatus == "inactive" ? "selected" : "")>Inactive</!option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button type="submit" class="btn btn-dark flex-grow-1 fw-bold">Filter</button>
                <a href="/Admin/Brands" class="btn btn-outline-secondary" title="Reset"><i class="fas fa-undo"></i></a>
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Brand Name</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@item.BrandId</td>
                                <td class="fw-bold text-dark">@item.BrandName</td>
                                <td class="text-muted small">@item.Description</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-2 py-1">
                                            <i class="fas fa-check-circle me-1 small"></i> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary px-2 py-1">
                                            <i class="fas fa-eye-slash me-1 small"></i> Inactive
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/Admin/EditBrand/@item.BrandId" class="btn btn-sm btn-outline-primary fw-bold shadow-sm me-1">
                                        Edit
                                    </a>

                                    <a href="/Admin/DeleteBrand/@item.BrandId" class="btn btn-sm btn-outline-danger fw-bold shadow-sm"
                                       onclick="return confirm('Are you sure you want to delete/hide this brand?');">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No brands found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Toastr logic (nếu chưa có trong Layout)
        $(document).ready(function () {
            var successMsg = '@TempData["Success"]';
            if (successMsg) toastr.success(successMsg, 'Success');
        });
    </script>
}