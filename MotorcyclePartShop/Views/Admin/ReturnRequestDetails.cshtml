@model MotorcyclePartShop.Models.ReturnRequest

@{
    ViewData["Title"] = "Return Request Details #" + Model.ReturnId;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-dark m-0">
            <a href="/Admin/ReturnRequests" class="text-decoration-none text-secondary me-2"><i class="fas fa-arrow-left"></i></a>
            Return Request <span class="text-danger">#@Model.ReturnId</span>
        </h4>
        
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white fw-bold py-3 border-bottom">
                    <i class="fas fa-info-circle text-primary me-2"></i> Request Information
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-bold">Customer Reason</label>
                            <p class="fs-5 fw-bold text-dark mt-1">@Model.Reason</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-bold">Request Date</label>
                            <p class="mt-1"><i class="far fa-clock me-1"></i> @Model.RequestedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="col-12 mt-2">
                            <label class="text-muted small text-uppercase fw-bold">Customer Note</label>
                            <div class="bg-light p-3 rounded border mt-1 text-secondary">
                                @(string.IsNullOrEmpty(Model.Note) ? "No details provided." : Model.Note)
                            </div>
                        </div>
                    </div>

                    <label class="text-muted small text-uppercase fw-bold mb-2">Evidence Image</label>
                    <div class="text-center bg-light rounded border p-3">
                        @if (!string.IsNullOrEmpty(Model.ImageEvidence))
                        {
                            <img src="~/images/returns/@Model.ImageEvidence" class="img-fluid rounded shadow-sm" style="max-height: 400px;">
                        }
                        else
                        {
                            <p class="text-muted m-0 py-5">No evidence image provided.</p>
                        }
                    </div>
                </div>
            </div>

            @if (Model.Status != "Pending")
            {
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-light fw-bold py-3 border-bottom">
                        <i class=" text-dark me-2"></i> Admin Response
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <label class="text-muted small text-uppercase fw-bold">Resolved Date</label>
                                <p class="mt-1">
                                    @(Model.ResolvedAt.HasValue ? Model.ResolvedAt.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")
                                </p>
                            </div>
                            <div class="col-12 mt-2">
                                <label class="text-muted small text-uppercase fw-bold">Admin Note</label>
                                <p class="mt-1 fw-bold text-dark">
                                    @(string.IsNullOrEmpty(Model.AdminNote) ? "No note recorded." : Model.AdminNote)
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light fw-bold py-3">
                    <i class="text-secondary me-2"></i> Order Summary
  
                        @if (Model.Status == "Pending")
                        {
                            <button class="btn btn-success fw-bold me-2" onclick="openProcessModal(@Model.ReturnId, 'Approve')">
                                <i class="fas fa-check me-2"></i> Approve
                            </button>
                            <button class="btn btn-danger fw-bold" onclick="openProcessModal(@Model.ReturnId, 'Reject')">
                                <i class="fas fa-times me-2"></i> Reject
                            </button>
                        }
                        else
                        {
                            <span class="badge @(Model.Status == "Approved" ? "bg-success" : "bg-secondary") fs-6 px-3 py-2">
                                @Model.Status
                            </span>
                        }
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Order Code:</span>
                        <a href="/Admin/OrderDetails/@Model.OrderId" class="fw-bold text-primary text-decoration-none">
                            #@Model.Order.TrackingCode
                        </a>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Total Amount:</span>
                        <span class="fw-bold text-danger">@Model.Order.TotalAmount.ToString("#,##0")₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Customer:</span>
                        <span class="fw-bold">@Model.Order.User?.FullName</span>
                    </div>

                    <hr>
                    <label class="text-muted small fw-bold mb-2">Products in Order</label>
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.Order.Items)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <img src="~/images/products/@item.Product.MainImage" width="40" height="40" class="rounded border me-2 object-fit-cover">
                                    <div style="line-height: 1.2;">
                                        <small class="fw-bold d-block text-truncate" style="max-width: 150px;">@item.Product.ProductName</small>
                                        <small class="text-muted">x @item.Quantity</small>
                                    </div>
                                </div>
                                <span class="small fw-bold">@((item.Price * item.Quantity).ToString("#,##0"))₫</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="processModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/Admin/ProcessReturn" method="post">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="processTitle">Process Request</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="ReturnId" id="processReturnId">
                    <input type="hidden" name="Status" id="processStatusInput">

                    <div class="alert" id="processAlert"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Admin Note (Optional)</label>
                        <textarea name="AdminNote" class="form-control" rows="3" placeholder="Enter reason or note for customer..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn fw-bold" id="processSubmitBtn">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openProcessModal(id, action) {
            var modal = new bootstrap.Modal(document.getElementById('processModal'));
            document.getElementById('processReturnId').value = id;

            var title = document.getElementById('processTitle');
            var alert = document.getElementById('processAlert');
            var statusInput = document.getElementById('processStatusInput');
            var btn = document.getElementById('processSubmitBtn');

            if (action === 'Approve') {
                title.innerText = "Approve Return Request";
                title.className = "modal-title fw-bold text-success";
                alert.className = "alert alert-success";
                alert.innerHTML = "<i class='fas fa-check-circle me-1'></i> Are you sure you want to <strong>APPROVE</strong> this request?";
                statusInput.value = "Approved";
                btn.className = "btn btn-success fw-bold";
                btn.innerText = "Yes, Approve";
            } else {
                title.innerText = "Reject Return Request";
                title.className = "modal-title fw-bold text-danger";
                alert.className = "alert alert-danger";
                alert.innerHTML = "<i class='fas fa-exclamation-triangle me-1'></i> Are you sure you want to <strong>REJECT</strong> this request?";
                statusInput.value = "Rejected";
                btn.className = "btn btn-danger fw-bold";
                btn.innerText = "Yes, Reject";
            }

            modal.show();
        }
    </script>
}