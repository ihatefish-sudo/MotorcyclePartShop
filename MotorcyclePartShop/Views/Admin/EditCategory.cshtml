@model MotorcyclePartShop.Models.Category
@{
    ViewData["Title"] = "Update Category";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0 fw-bold"><i class=" me-2"></i> Update Category</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="EditCategory" method="post">

                    <input type="hidden" asp-for="CategoryId" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Category Name <span class="text-danger">*</span></label>
                        <input asp-for="CategoryName" class="form-control" required />
                        <span asp-validation-for="CategoryName" class="text-danger small"></span>
                    </div>

                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" asp-for="IsActive" id="statusSwitch" style="cursor: pointer;">
                        <label class="form-check-label fw-bold @(Model.IsActive ? "text-success" : "text-secondary")" for="statusSwitch" id="statusLabel">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </label>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/Admin/Categories" class="btn btn-secondary">Back</a>
                        <button type="submit" class="btn btn-primary px-4 fw-bold">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Script to change status text color when switch is toggled
        document.getElementById('statusSwitch').addEventListener('change', function() {
            const label = document.getElementById('statusLabel');
            if(this.checked) {
                label.textContent = "Active";
                label.className = "form-check-label fw-bold text-success";
            } else {
                label.textContent = "Inactive";
                label.className = "form-check-label fw-bold text-secondary";
            }
        });
    </script>
}