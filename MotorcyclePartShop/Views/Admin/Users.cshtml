@model IEnumerable<MotorcyclePartShop.Models.User>

@{
    ViewData["Title"] = "User Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 mb-4">

    <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold"> USER MANAGEMENT</h5>
        <a href="/Admin/CreateUser" class="btn btn-sm btn-light text-danger fw-bold shadow-sm">
            <i class="fas fa-user-plus me-1"></i> Add User
        </a>
    </div>

    <div class="card-body bg-light border-bottom">
        <form action="/Admin/Users" method="get" class="row g-2 align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="search" class="form-control border-start-0 ps-0"
                           placeholder="Search Name, Email, Phone..." value="@ViewBag.CurrentSearch">
                </div>
            </div>
            <div class="col-md-3">
                <select name="role" class="form-select" onchange="this.form.submit()">
                    <option value="">-- All Roles --</option>
                    @if (ViewBag.Roles != null)
                    {
                        foreach (var r in ViewBag.Roles as List<MotorcyclePartShop.Models.Role>)
                        {
                            <!option value="@r.RoleName" @(ViewBag.CurrentRole == r.RoleName ? "selected" : "")>@r.RoleName</!option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select" onchange="this.form.submit()">
                    <option value="">-- All Status --</option>
                    <!option value="active" @(ViewBag.CurrentStatus == "active" ? "selected" : "")>Active</!option>
                    <!option value="locked" @(ViewBag.CurrentStatus == "locked" ? "selected" : "")>Locked</!option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button type="submit" class="btn btn-dark flex-grow-1 fw-bold">Filter</button>
                <a href="/Admin/Users" class="btn btn-outline-secondary" title="Reset"><i class="fas fa-undo"></i></a>
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="ps-4">Full Name</th>
                        <th>Contact Info</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Created Date</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.FullName</div>
                                    <small class="text-muted">ID: #@item.UserId</small>
                                </td>
                                <td>
                                    <div><i class="far fa-envelope text-muted me-2 small"></i> @item.Email</div>
                                    <div class="small text-muted mt-1"><i class="fas fa-phone-alt text-muted me-2 small"></i> @item.Phone</div>
                                </td>
                                <td>
                                    @foreach (var role in item.UserRoles)
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info border border-info px-2 py-1 me-1">
                                            @role.Role.RoleName
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-2 py-1">
                                            <i class=" me-1 small"></i> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary px-2 py-1">
                                            <i class=" me-1 small"></i> Locked
                                        </span>
                                    }
                                </td>
                                <td class="small text-muted">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td class="text-end pe-4">
                                    <a href="/Admin/EditUser/@item.UserId" class="btn btn-sm btn-outline-primary me-1 fw-bold" title="Edit">
                                        Edit
                                    </a>

                                    <button type="button"
                                            class="btn btn-sm @(item.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                                            data-bs-toggle="modal"
                                            data-bs-target="#statusModal"
                                            data-url="/Admin/ToggleUserStatus/@item.UserId"
                                            data-username="@item.FullName"
                                            data-status="@(item.IsActive ? "Lock" : "Unlock")"
                                            title="@(item.IsActive ? "Lock Account" : "Unlock Account")">
                                        <i class="fas @(item.IsActive ? "fa-lock" : "fa-lock-open")"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-users-slash fa-3x mb-3 text-secondary opacity-50"></i>
                <p class="mb-0">No users found matching your criteria.</p>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="statusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white border-bottom-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-user-cog me-2"></i> Confirm Action
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4 text-center">
                <div class="mb-3">
                    <i id="modalIcon" class="fas fa-exclamation-circle text-warning display-4"></i>
                </div>
                <p class="mb-1 fs-5">Are you sure you want to <strong id="actionText" class="text-uppercase"></strong> this account?</p>
                <p class="text-muted small">User: <strong id="userTarget" class="text-dark"></strong></p>
            </div>
            <div class="modal-footer border-top-0 justify-content-center pb-4">
                <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Cancel</button>
                <a href="#" id="confirmBtn" class="btn btn-warning px-4 fw-bold shadow-sm">Confirm</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        // 2. Cấu hình Toastr
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "3000"
        };

        // 3. Logic hiển thị Toastr từ TempData
        $(document).ready(function () {
            var successMsg = '@TempData["Success"]';
            var errorMsg = '@TempData["Error"]';

            if (successMsg) {
                toastr.success(successMsg, 'Success');
            }
            if (errorMsg) {
                toastr.error(errorMsg, 'Error');
            }
        });

        // 4. Logic xử lý Modal (Giữ nguyên)
        var statusModal = document.getElementById('statusModal');
        if (statusModal) {
            statusModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var url = button.getAttribute('data-url');
                var username = button.getAttribute('data-username');
                var status = button.getAttribute('data-status');

                var confirmBtn = statusModal.querySelector('#confirmBtn');
                var actionText = statusModal.querySelector('#actionText');
                var userTarget = statusModal.querySelector('#userTarget');
                var modalIcon = statusModal.querySelector('#modalIcon');

                confirmBtn.href = url;
                actionText.textContent = status;
                userTarget.textContent = username;

                confirmBtn.className = "btn px-4 fw-bold shadow-sm";
                modalIcon.className = "fas display-4 mb-3";

                if (status === "Lock") {
                    confirmBtn.classList.add("btn-danger");
                    confirmBtn.textContent = "Yes, Lock It";
                    modalIcon.classList.add("fa-lock", "text-danger");
                } else {
                    confirmBtn.classList.add("btn-success", "text-white");
                    confirmBtn.textContent = "Yes, Unlock It";
                    modalIcon.classList.add("fa-lock-open", "text-success");
                }
            });
        }
    </script>
}