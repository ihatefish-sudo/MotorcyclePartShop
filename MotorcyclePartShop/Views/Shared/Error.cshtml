@model MotorcyclePartShop.Models.ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}

<div class="container text-center py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="mb-4">
                <i class="fas fa-exclamation-triangle text-danger fa-5x"></i>
            </div>

            <h1 class="text-danger fw-bold">Đã có lỗi xảy ra!</h1>
            <p class="lead text-secondary mb-4">
                Hệ thống gặp sự cố khi xử lý yêu cầu của bạn. Vui lòng thử lại sau giây lát.
            </p>

            @if (Model.ShowRequestId)
            {
                <div class="alert alert-warning d-inline-block">
                    <strong>Request ID:</strong> <code>@Model.RequestId</code>
                </div>
                <p class="small text-muted mt-2">
                    Hãy cung cấp ID này cho quản trị viên nếu lỗi vẫn tiếp diễn.
                </p>
            }

            <div class="mt-4">
                <a href="/" class="btn btn-primary px-4">
                    <i class="fas fa-home me-2"></i> Quay về Trang chủ
                </a>
            </div>
        </div>
    </div>
</div>