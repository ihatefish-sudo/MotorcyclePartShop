@using Microsoft.AspNetCore.Http
@using MotorcyclePartShop.Data          @* For DbContext *@
@using MotorcyclePartShop.Extensions
@using MotorcyclePartShop.Models
@using Microsoft.EntityFrameworkCore    @* For ToListAsync if needed *@

@inject IHttpContextAccessor HttpContextAccessor
@inject MotorcyclePartShopDbContext _context

<header class="fixed-top shadow-sm" id="site-header" style="z-index: 1030;">

    <div class="header-top py-3 bg-white border-bottom">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-3 col-4">
                    <a href="/" class="text-decoration-none">
                        <h2 class="m-0 text-danger fw-bold"><i class="fas fa-motorcycle"></i> MOTO SHOP</h2>
                    </a>
                </div>

                <div class="col-md-5 d-none d-md-block position-relative">
                    <form action="/Product" method="get" class="input-group">
                        <input type="text" name="search" id="searchInput" class="form-control"
                               placeholder="Search for parts, lubricants..." autocomplete="off">
                        <button class="btn btn-danger" type="submit"><i class="fas fa-search"></i></button>
                    </form>
                    <div id="searchSuggestions" class="list-group position-absolute w-100 shadow mt-1"
                         style="z-index: 1000; display: none; border-radius: 0 0 5px 5px; overflow: hidden;">
                    </div>
                </div>

                <div class="col-md-4 col-8 d-flex justify-content-end align-items-center gap-2">
                    <div class="d-none d-lg-block text-end me-3">
                        <span class="d-block text-muted small" style="font-size: 12px;">Support Hotline</span>
                        <strong class="text-danger">1900 xxxx</strong>
                    </div>

                    @{
                        var session = HttpContextAccessor.HttpContext.Session;
                        var userId = session.GetString("UserId");
                        var userName = session.GetString("UserName");
                        var cart = session.GetObjectFromJson<List<CartItem>>("Cart");
                        int cartCount = cart != null ? cart.Sum(item => item.Quantity) : 0;
                    }

                    @if (string.IsNullOrEmpty(userId))
                    {
                        <a href="/Auth/Login" class="btn btn-outline-danger btn-sm d-flex align-items-center">
                            <i class="far fa-user me-2"></i><span class="fw-bold">Login</span>
                        </a>
                    }
                    else
                    {
                        <div class="dropdown">
                            <a href="#" class="btn btn-light btn-sm dropdown-toggle d-flex align-items-center" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle text-danger me-2"></i>
                                <span class="d-inline-block text-truncate" style="max-width: 100px;">@userName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li><span class="dropdown-item-text text-muted small">Hello, <strong>@userName</strong></span></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/Order/History"><i class="fas fa-box me-2"></i>Order History</a></li>
                                <li><a class="dropdown-item" href="/Account/Profile"><i class="fas fa-user-cog me-2"></i>My Account</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger fw-bold" href="/Auth/Logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                            </ul>
                        </div>
                    }

                    <a href="/Cart" class="position-relative btn btn-light btn-sm ms-1">
                        <i class="fas fa-shopping-cart text-danger"></i>
                        <span id="cartCountBadge"
                              class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger @(cartCount > 0 ? "" : "d-none")"
                              style="font-size: 10px;">
                            @cartCount
                        </span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="header-nav bg-danger">
        <div class="container">
            <nav class="navbar navbar-expand-lg navbar-dark p-0">
                <button class="navbar-toggler my-2" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span> Categories
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link text-white fw-bold px-3 py-3" href="/"><i class="fas fa-home"></i> HOME</a></li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white fw-bold px-3 py-3" href="#" data-bs-toggle="dropdown">PRODUCTS</a>
                            <ul class="dropdown-menu shadow">
                                <li><a class="dropdown-item fw-bold" href="/Product">All Products</a></li>
                                <li><hr class="dropdown-divider"></li>

                                @{
                                    var categories = _context.Categories.Where(c => c.IsActive).ToList();
                                }

                                @foreach (var cat in categories)
                                {
                                    <li>
                                        <a class="dropdown-item" href="/Product?categoryId=@cat.CategoryId">
                                            @cat.CategoryName
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>
                        <li class="nav-item"><a class="nav-link text-white fw-bold px-3 py-3" href="/Promotion/Index">PROMOTION</a></li>
                        <li class="nav-item"><a class="nav-link text-white fw-bold px-3 py-3" href="/Product/Compare">PRODUCT COMPARISON</a></li>
                        <li class="nav-item"><a class="nav-link text-white fw-bold px-3 py-3" href="/Order/TrackOrder">TRACK ORDER</a></li>
                        <li class="nav-item"><a class="nav-link text-white fw-bold px-3 py-3" href="/Home/About">ABOUT US</a></li>
                    </ul>
                </div>
            </nav>
        </div>
    </div>
</header>

<script>
    document.addEventListener("DOMContentLoaded", function() {

        // --- 1. Xử lý Search Suggestion (Giữ nguyên code cũ) ---
        const searchInput = document.getElementById("searchInput");
        const suggestionBox = document.getElementById("searchSuggestions");
        let timeout = null;

        if(searchInput) {
            searchInput.addEventListener("input", function() {
                const query = this.value;
                clearTimeout(timeout);
                if (query.length < 2) {
                    suggestionBox.style.display = "none";
                    suggestionBox.innerHTML = "";
                    return;
                }
                timeout = setTimeout(() => {
                    fetch(`/Product/SearchSuggestions?query=${encodeURIComponent(query)}`)
                        .then(response => response.json())
                        .then(data => {
                            suggestionBox.innerHTML = "";
                            if (data.length > 0) {
                                suggestionBox.style.display = "block";
                                data.forEach(item => {
                                    let imgSrc = item.image.startsWith("http") ? item.image : "/images/products/" + item.image;
                                    const a = document.createElement("a");
                                    a.href = `/Product/Details/${item.id}`;
                                    a.className = "list-group-item list-group-item-action d-flex align-items-center";
                                    a.innerHTML = `<img src="${imgSrc}" style="width: 40px; height: 40px; object-fit: cover;" class="me-2 rounded border">
                                                   <div class="flex-grow-1 text-truncate"><div class="small fw-bold text-dark">${item.name}</div><div class="text-danger small fw-bold">${item.price}</div></div>`;
                                    suggestionBox.appendChild(a);
                                });
                            } else { suggestionBox.style.display = "none"; }
                        }).catch(err => console.error(err));
                }, 300);
            });
            document.addEventListener("click", function(e) {
                if (!searchInput.contains(e.target) && !suggestionBox.contains(e.target)) suggestionBox.style.display = "none";
            });
        }

        // --- 2. Xử lý Fixed Header ---
        // Tự động tính chiều cao Header và đẩy body xuống
        function adjustBodyPadding() {
            var header = document.getElementById('site-header');
            if (header) {
                var headerHeight = header.offsetHeight;
                document.body.style.paddingTop = headerHeight + 'px';
            }
        }

        // Gọi ngay khi load và khi resize màn hình
        adjustBodyPadding();
        window.addEventListener('resize', adjustBodyPadding);
    });
</script>
<script>
    // Script chạy ở mọi trang để cập nhật Navbar
    document.addEventListener("DOMContentLoaded", function() {
        const COMPARE_KEY_GLOBAL = 'moto_compare_ids';
        let ids = JSON.parse(localStorage.getItem(COMPARE_KEY_GLOBAL)) || [];
        let badge = document.getElementById('navCompareCount');
        if(badge) {
            if (ids.length > 0) {
                badge.innerText = ids.length;
                badge.style.display = 'inline-block';
            } else {
                badge.style.display = 'none';
            }
        }
    });

    // Hàm chuyển hướng (Global)
    function goToComparePage() {
        const COMPARE_KEY_GLOBAL = 'moto_compare_ids';
        let currentIds = JSON.parse(localStorage.getItem(COMPARE_KEY_GLOBAL)) || [];
        if (currentIds.length > 0) {
            window.location.href = `/Product/Compare?ids=${currentIds.join(',')}`;
        } else {
            window.location.href = `/Product/Compare`;
        }
    }
</script>