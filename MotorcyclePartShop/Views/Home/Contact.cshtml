@{
    ViewData["Title"] = "Contact Us";
}

<div class="bg-light py-4 mb-5">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-dark">Home</a></li>
                <li class="breadcrumb-item active text-danger fw-bold" aria-current="page">Contact Us</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container mb-5">
    <div class="text-center mb-5">
        <h2 class="text-uppercase fw-bold text-danger">
            <i class="fas fa-envelope-open-text me-2"></i> Get In Touch
        </h2>
        <p class="text-muted">We'd love to hear from you. Here is how you can reach us.</p>
        <div class="d-flex justify-content-center">
            <div style="width: 60px; height: 3px; background-color: #d70018;"></div>
        </div>
    </div>

    <div class="row g-5">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100 bg-danger text-white position-relative overflow-hidden">
                <div class="position-absolute top-0 end-0 bg-white opacity-10 rounded-circle" style="width: 150px; height: 150px; margin-top: -50px; margin-right: -50px;"></div>
                <div class="position-absolute bottom-0 start-0 bg-white opacity-10 rounded-circle" style="width: 150px; height: 150px; margin-bottom: -50px; margin-left: -50px;"></div>

                <div class="card-body p-5 position-relative" style="z-index: 2;">
                    <h4 class="fw-bold mb-4">Contact Information</h4>
                    <p class="mb-4 text-white-50">Fill up the form and our Team will get back to you within 24 hours.</p>

                    <div class="d-flex mb-4 align-items-start">
                        <div class="icon-box bg-white text-danger rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; min-width: 40px;">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Our Store</h6>
                            <p class="mb-0 text-white-50 small">123 ABC Street, District X, Ho Chi Minh City, Vietnam</p>
                        </div>
                    </div>

                    <div class="d-flex mb-4 align-items-start">
                        <div class="icon-box bg-white text-danger rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; min-width: 40px;">
                            <i class="fas fa-phone-alt"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Phone Number</h6>
                            <p class="mb-0 text-white-50 small">1900 xxxx (Hotline)</p>
                            <p class="mb-0 text-white-50 small">0909 123 456 (Support)</p>
                        </div>
                    </div>

                    <div class="d-flex mb-4 align-items-start">
                        <div class="icon-box bg-white text-danger rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; min-width: 40px;">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Email Address</h6>
                            <p class="mb-0 text-white-50 small">support@motoshop.com</p>
                            <p class="mb-0 text-white-50 small">sales@motoshop.com</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-start">
                        <div class="icon-box bg-white text-danger rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; min-width: 40px;">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Working Hours</h6>
                            <p class="mb-0 text-white-50 small">Mon - Sun: 8:00 AM - 8:00 PM</p>
                        </div>
                    </div>

                    <div class="mt-5">
                        <h6 class="fw-bold mb-3">Follow Us</h6>
                        <div class="d-flex gap-3">
                            <a href="#" class="text-white fs-5 hover-scale"><i class="fab fa-facebook"></i></a>
                            <a href="#" class="text-white fs-5 hover-scale"><i class="fab fa-youtube"></i></a>
                            <a href="#" class="text-white fs-5 hover-scale"><i class="fab fa-tiktok"></i></a>
                            <a href="#" class="text-white fs-5 hover-scale"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100 p-4">
                <div class="card-body">
                    <h4 class="fw-bold text-dark mb-4">Send us a Message</h4>
                    <form>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-secondary">Your Name</label>
                                <input type="text" class="form-control bg-light border-0 py-3" placeholder="John Doe">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-secondary">Phone Number</label>
                                <input type="tel" class="form-control bg-light border-0 py-3" placeholder="+84 909...">
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small text-secondary">Email Address</label>
                                <input type="email" class="form-control bg-light border-0 py-3" placeholder="name@example.com">
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small text-secondary">Subject</label>
                                <select class="form-select bg-light border-0 py-3">
                                    <option>General Inquiry</option>
                                    <option>Order Support</option>
                                    <option>Product Warranty</option>
                                    <option>Partnership</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small text-secondary">Message</label>
                                <textarea class="form-control bg-light border-0" rows="5" placeholder="How can we help you?"></textarea>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-danger px-5 py-3 fw-bold rounded-pill w-100 w-md-auto">
                                    <i class="fas fa-paper-plane me-2"></i> Send Message
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5 pt-4">
        <div class="col-12">
            <h4 class="fw-bold mb-4 border-start border-5 border-danger ps-3">Find Us on Google Maps</h4>
            <div class="ratio ratio-21x9 shadow-sm rounded overflow-hidden border">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.494578332997!2d106.6999493148007!3d10.773380992323678!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f40a3b46163%3A0x1424302927c3da4d!2zQ2hvIELhur9uIFRow6BuaA!5e0!3m2!1svi!2s!4v1645432123456!5m2!1svi!2s" 
                        allowfullscreen="" loading="lazy"></iframe>
            </div>
        </div>
    </div>
</div>

<style>
    /* Hover effect for social icons */
    .hover-scale {
        transition: transform 0.2s;
    }
    .hover-scale:hover {
        transform: scale(1.2);
        color: #f8f9fa !important;
    }

    /* Input focus styling to match theme */
    .form-control:focus, .form-select:focus {
        background-color: #fff !important;
        border: 1px solid #d70018 !important;
        box-shadow: 0 0 0 0.25rem rgba(215, 0, 24, 0.1);
    }
</style>