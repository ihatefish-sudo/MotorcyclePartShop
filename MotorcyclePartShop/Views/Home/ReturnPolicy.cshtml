@{
    ViewData["Title"] = "Return Policy";
}

<div class="bg-light py-4 mb-5">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-dark">Home</a></li>
                <li class="breadcrumb-item active text-danger fw-bold" aria-current="page">Return Policy</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <div class="col-lg-9 mx-auto">
            <h2 class="text-danger fw-bold text-uppercase mb-4 text-center border-bottom pb-3 border-danger">Return Policy</h2>

            <div class="policy-content text-secondary">
                <p class="lead">
                    At <strong>Moto Shop</strong>, we always cherish the trust of our customers. Our after-sales policy is built on a commitment to protect consumer rights so you can shop and experience our services with peace of mind.
                </p>

                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-danger text-white fw-bold">
                        <i class="far fa-clock me-2"></i> 1. Time & Scope of Application
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> <strong>Time:</strong> Within <span class="fw-bold text-danger">15 days</span> from the date of purchase (based on the invoice or delivery date).</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> <strong>Scope:</strong> Applies to all products purchased on the Website and at the Store.</li>
                            <li><i class="fas fa-exclamation-circle text-warning me-2"></i> <strong>Note:</strong> Returns are not applicable for products in clearance sales programs or online vouchers.</li>
                        </ul>
                    </div>
                </div>

                <h5 class="fw-bold text-dark mt-4 mb-3">2. Return Conditions</h5>
                <p>Products are accepted for return when satisfying the following conditions:</p>
                <ul class="list-group mb-4">
                    <li class="list-group-item">
                        <i class="fas fa-box-open text-primary me-2"></i> Product must have original tags, labels, and manufacturer seals intact.
                    </li>
                    <li class="list-group-item">
                        <i class="fas fa-hand-sparkles text-primary me-2"></i> Product must be unused, not dirty, scratched, broken, damaged, or have strange odors.
                    </li>
                    <li class="list-group-item">
                        <i class="fas fa-receipt text-primary me-2"></i> Must have full purchase invoice, warranty card (if any), and accompanying accessories.
                    </li>
                    <li class="list-group-item">
                        <i class="fas fa-exclamation-triangle text-primary me-2"></i> Product has technical defects caused by the manufacturer or errors from Moto Shop (wrong item delivered, missing items).
                    </li>
                </ul>

                <h5 class="fw-bold text-dark mt-4 mb-3">3. Return Process</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="p-3 border rounded bg-light h-100 text-center">
                            <div class="mb-2 text-danger fs-3"><i class="fas fa-phone-alt"></i></div>
                            <strong>Step 1: Contact</strong>
                            <p class="small mt-2">Call hotline <strong>1900 xxxx</strong> or email <code>support@motoshop.com</code> to notify your request.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 border rounded bg-light h-100 text-center">
                            <div class="mb-2 text-danger fs-3"><i class="fas fa-shipping-fast"></i></div>
                            <strong>Step 2: Send Product</strong>
                            <p class="small mt-2">Pack the product carefully with the invoice and send it to the store address.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 border rounded bg-light h-100 text-center">
                            <div class="mb-2 text-danger fs-3"><i class="fas fa-sync-alt"></i></div>
                            <strong>Step 3: Processing</strong>
                            <p class="small mt-2">We check and proceed with exchange or refund within 3-5 working days.</p>
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold text-dark mt-4 mb-3">4. Refund Method & Fees</h5>
                <div class="alert alert-secondary">
                    <p class="mb-2"><strong><i class="fas fa-money-bill-wave me-2"></i> Refund:</strong></p>
                    <ul class="mb-3">
                        <li>If manufacturer defect: 100% exchange or full refund.</li>
                        <li>If customer changes mind (non-defect): 10% restocking fee applies.</li>
                    </ul>

                    <p class="mb-0"><strong><i class="fas fa-truck me-2"></i> Shipping Fee:</strong></p>
                    <ul>
                        <li>Moto Shop error: Free 2-way shipping.</li>
                        <li>Subjective reason from customer: Customer pays shipping fee.</li>
                    </ul>
                </div>

                <div class="mt-5 text-center">
                    <p>For any questions, please contact our Customer Care department:</p>
                    <a href="tel:1900xxxx" class="btn btn-danger btn-lg rounded-pill px-5 shadow fw-bold">
                        <i class="fas fa-headset me-2"></i> 1900 xxxx
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .policy-content {
        line-height: 1.8;
        font-size: 1.05rem;
    }

    .list-group-item {
        border: none;
        background-color: #f8f9fa;
        margin-bottom: 5px;
    }
</style>