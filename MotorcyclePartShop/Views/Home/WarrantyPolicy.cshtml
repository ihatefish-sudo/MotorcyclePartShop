@{
    ViewData["Title"] = "Warranty Policy";
}

<div class="bg-light py-4 mb-5">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-dark">Home</a></li>
                <li class="breadcrumb-item active text-danger fw-bold" aria-current="page">Warranty Policy</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <h2 class="text-danger fw-bold text-uppercase mb-4 text-center border-bottom pb-3 border-danger">
                Product Warranty Policy
            </h2>

            <div class="policy-content text-secondary">
                <p class="lead text-center mb-5">
                    <strong>Moto Shop</strong> is committed to selling only genuine products, warranted according to manufacturer standards. Below are the specific regulations regarding our warranty policy.
                </p>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-header bg-danger text-white fw-bold">
                                <i class="fas fa-shield-alt me-2"></i> 1. Valid Warranty Conditions
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled">
                                    <li class="mb-3 d-flex">
                                        <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                                        <span>Product is within the specified **warranty period** (usually 6 - 12 months depending on the part).</span>
                                    </li>
                                    <li class="mb-3 d-flex">
                                        <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                                        <span>Product has technical defects caused by the manufacturer (natural cracking, electrical circuit faults, machining errors...).</span>
                                    </li>
                                    <li class="mb-3 d-flex">
                                        <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                                        <span>Still possess the **purchase invoice** or warranty card (if any) from Moto Shop.</span>
                                    </li>
                                    <li class="d-flex">
                                        <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                                        <span>Warranty seal (if any) must be intact, not torn or erased.</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-header bg-dark text-white fw-bold">
                                <i class="fas fa-ban me-2"></i> 2. Cases Not Covered by Warranty
                            </div>
                            <div class="card-body bg-light">
                                <ul class="list-unstyled">
                                    <li class="mb-3 d-flex">
                                        <i class="fas fa-times-circle text-danger me-2 mt-1"></i>
                                        <span>Product warranty has expired.</span>
                                    </li>
                                    <li class="mb-3 d-flex">
                                        <i class="fas fa-times-circle text-danger me-2 mt-1"></i>
                                        <span>Damage caused by **user**: Improper installation, impact, accidents, misuse.</span>
                                    </li>
                                    <li class="mb-3 d-flex">
                                        <i class="fas fa-times-circle text-danger me-2 mt-1"></i>
                                        <span>Product structure has been altered, modified, or repaired elsewhere.</span>
                                    </li>
                                    <li class="d-flex">
                                        <i class="fas fa-times-circle text-danger me-2 mt-1"></i>
                                        <span>Natural wear and tear during use (Brake pads, sprockets, tires...).</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-5">
                    <h4 class="fw-bold text-dark mb-4 border-start border-5 border-danger ps-3">3. Warranty Process</h4>

                    <div class="row text-center">
                        <div class="col-md-4 mb-3">
                            <div class="p-4 border rounded bg-white shadow-sm h-100">
                                <div class="icon-box bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                                    <span class="fw-bold fs-4">1</span>
                                </div>
                                <h6 class="fw-bold">Receive Information</h6>
                                <p class="small text-muted">Customers bring the defective product to the store or send it via express delivery with a description of the error.</p>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="p-4 border rounded bg-white shadow-sm h-100">
                                <div class="icon-box bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                                    <span class="fw-bold fs-4">2</span>
                                </div>
                                <h6 class="fw-bold">Check & Confirm</h6>
                                <p class="small text-muted">Technicians will inspect the defect. Inspection time is 1 - 3 working days.</p>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="p-4 border rounded bg-white shadow-sm h-100">
                                <div class="icon-box bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                                    <span class="fw-bold fs-4">3</span>
                                </div>
                                <h6 class="fw-bold">Warranty Return</h6>
                                <p class="small text-muted">If the fault is from the manufacturer, we will exchange or repair it for free and send it back to you.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-warning mt-5 d-flex align-items-center shadow-sm">
                    <i class="fas fa-headset fa-3x me-4 text-danger"></i>
                    <div>
                        <h5 class="fw-bold text-dark">Moto Shop Warranty Center</h5>
                        <p class="mb-1"><i class="fas fa-map-marker-alt me-2"></i> 123 ABC Street, District X, HCMC</p>
                        <p class="mb-0"><i class="fas fa-phone-alt me-2"></i> Hotline: <strong class="text-danger">1900 xxxx</strong> (8:00 AM - 5:30 PM)</p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .policy-content {
        line-height: 1.7;
        font-size: 1.05rem;
    }

    .card-header {
        font-size: 1.1rem;
        padding: 15px;
    }
</style>