@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Hoặc layout login của bạn
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <h3 class="fw-bold text-danger mb-3">Quên Mật Khẩu?</h3>
                    <p class="text-muted small mb-4">Nhập email của bạn để nhận mã xác thực OTP.</p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form asp-action="ForgotPassword" method="post">
                        <div class="mb-3 text-start">
                            <label class="form-label fw-bold">Email đăng ký</label>
                            <input type="email" name="email" class="form-control" placeholder="name@example.com" required />
                        </div>
                        <button type="submit" class="btn btn-danger w-100 fw-bold">Gửi Mã OTP</button>
                    </form>
                    <div class="mt-3">
                        <a href="/Auth/Login" class="text-decoration-none small"><i class="fas fa-arrow-left"></i> Quay lại Đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>