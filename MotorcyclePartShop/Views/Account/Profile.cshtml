@model MotorcyclePartShop.Models.User
@{
    ViewData["Title"] = "Personal Information";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-user-edit me-2"></i> ACCOUNT INFORMATION</h5>
                    <a href="/Account/ChangePassword" class="btn btn-sm btn-light text-danger fw-bold shadow-sm">
                        <i class="fas fa-key me-1"></i> Change Password
                    </a>
                </div>
                <div class="card-body p-4">

                    <form asp-action="UpdateProfile" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted">Login Email</label>
                            <input type="text" class="form-control bg-light" value="@Model.Email" readonly disabled>
                            <small class="text-muted">Email cannot be changed.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Full Name</label>
                            <input asp-for="FullName" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Phone Number</label>
                            <input asp-for="Phone" class="form-control" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Default Shipping Address</label>
                            <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/" class="btn btn-outline-secondary">Back to Home</a>
                            <button type="submit" class="btn btn-danger px-4 fw-bold">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        // 2. Cấu hình Toastr (Tùy chọn cho đẹp)
        toastr.options = {
            "closeButton": true,       // Hiện nút tắt
            "progressBar": true,       // Hiện thanh thời gian
            "positionClass": "toast-top-right", // Vị trí: Góc trên phải
            "timeOut": "3000"          // Tự tắt sau 3 giây
        };

        $(document).ready(function () {
            // 3. Kiểm tra TempData từ Controller gửi sang
            var successMsg = '@TempData["Success"]';
            var errorMsg = '@TempData["Error"]'; // Thêm cái này phòng hờ có lỗi

            if (successMsg) {
                toastr.success(successMsg, 'Success');
            }

            if (errorMsg) {
                toastr.error(errorMsg, 'Error');
            }
        });
    </script>
}