@model MotorcyclePartShop.Models.Order

@{
    ViewData["Title"] = "Order Details #" + Model.TrackingCode;
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-danger pb-2">
        <h3 class="text-uppercase fw-bold m-0">
            <i class="fas fa-file-invoice text-danger me-2"></i> Order Details
        </h3>
        <a href="/Order/History" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i> Back
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light fw-bold">Shipping Information</div>
                <div class="card-body">
                    <p class="mb-1"><strong>Order Code:</strong> <span class="text-primary fw-bold">#@Model.TrackingCode</span></p>
                    <p class="mb-1"><strong>Order Date:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-1"><strong>Address:</strong> @Model.ShippingAddress</p>
                    <p class="mb-0"><strong>Payment:</strong> @Model.PaymentMethod <span class="badge bg-secondary ms-2">@Model.PaymentStatus</span></p>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light fw-bold">Purchased Products</div>
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@(item.Product.MainImage.StartsWith("http") ? item.Product.MainImage : "/images/products/" + item.Product.MainImage)"
                                                 width="50" height="50" class="rounded border me-2" style="object-fit:cover;">
                                            <div>
                                                <a href="/Product/Details/@item.ProductId" class="text-dark text-decoration-none fw-bold small">
                                                    @item.Product.ProductName
                                                </a>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center align-middle">@item.Quantity</td>
                                    <td class="text-end align-middle">@item.Price.ToString("#,##0")₫</td>
                                    <td class="text-end align-middle fw-bold">@((item.Price * item.Quantity).ToString("#,##0"))₫</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Grand Total:</td>
                                <td class="text-end fw-bold text-danger fs-5">@Model.TotalAmount.ToString("#,##0")₫</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-danger text-white fw-bold">
                    <i class="fas fa-truck me-2"></i> ORDER STATUS
                </div>
                <div class="card-body">

                    <div class="mb-4 d-grid gap-2">
                        @if (Model.PaymentMethod == "VNPAY" && Model.PaymentStatus == "Pending" && Model.DeliveryStatus != "Cancelled" && Model.DeliveryStatus != "CANCELLED")
                        {
                            <div class="alert alert-warning py-2 mb-2 text-center small">
                                <i class="fas fa-exclamation-circle"></i> Unpaid Order
                            </div>
                            <a href="/Payment/CreatePaymentUrl?orderId=@Model.OrderId" class="btn btn-danger fw-bold py-2">
                                <i class="fas fa-credit-card me-2"></i> Pay Now (VNPAY)
                            </a>
                        }

                        @if (Model.DeliveryStatus == "Pending")
                        {
                            <button type="button"
                                    class="btn btn-outline-danger fw-bold py-2"
                                    data-bs-toggle="modal"
                                    data-bs-target="#cancelModal">
                                <i class="fas fa-times me-2"></i> Cancel Order
                            </button>
                        }
                        else if (Model.DeliveryStatus == "Shipping")
                        {
                            <button type="button"
                                    class="btn btn-success fw-bold py-2"
                                    data-bs-toggle="modal"
                                    data-bs-target="#receivedModal">
                                <i class="fas fa-check-circle me-2"></i> I Have Received Order
                            </button>
                        }
                        else if (Model.DeliveryStatus == "Completed")
                        {
                            <a href="/Order/Return/@Model.OrderId" class="btn btn-outline-danger fw-bold py-2">
                                <i class="fas fa-undo-alt me-2"></i> Return / Refund
                            </a>
                        }
                        else if (Model.DeliveryStatus == "Cancelled" || Model.DeliveryStatus == "CANCELLED")
                        {
                            <div class="alert alert-danger text-center mb-0 fw-bold">
                                ORDER CANCELLED
                            </div>
                        }
                    </div>

                    @if (Model.Tracking != null && Model.Tracking.Any())
                    {
                        <div class="tracking-timeline">
                            @foreach (var track in Model.Tracking.OrderByDescending(t => t.UpdatedAt))
                            {
                                <div class="timeline-item">
                                    <div class="timeline-marker"></div>
                                    <div class="timeline-content">
                                        <h6 class="fw-bold mb-1 text-dark">@track.Status</h6>
                                        <small class="text-muted"><i class="far fa-clock me-1"></i> @track.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">No updates available yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="receivedModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white border-bottom-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-box-check me-2"></i> Confirm Delivery
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4 text-center">
                <div class="mb-3">
                    <i class="fas fa-check-circle text-success display-3"></i>
                </div>
                <h5 class="fw-bold">Have you received your order?</h5>
                <p class="text-muted small mb-0">
                    By confirming, the order status will be updated to "Completed".
                </p>
            </div>
            <div class="modal-footer border-top-0 justify-content-center pb-4">
                <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Not yet</button>
                <a href="/Order/ConfirmReceived/@Model.OrderId" class="btn btn-success px-4 fw-bold">
                    Yes, I Received It
                </a>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white border-bottom-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-exclamation-triangle me-2"></i> Cancel Order
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4 text-center">
                <div class="mb-3">
                    <i class="fas fa-times-circle text-danger display-3"></i>
                </div>
                <h5 class="fw-bold">Are you sure you want to cancel?</h5>
                <p class="text-muted small mb-0">
                    This action cannot be undone. If you paid via VNPAY, the amount will be refunded.
                </p>
            </div>
            <div class="modal-footer border-top-0 justify-content-center pb-4">
                <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Close</button>

                <form asp-controller="Order" asp-action="CancelOrder" asp-route-id="@Model.OrderId" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger px-4 fw-bold">
                        Yes, Cancel Order
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .tracking-timeline {
        position: relative;
        padding-left: 20px;
        margin-top: 10px;
        border-left: 2px solid #e9ecef;
    }

    .timeline-item {
        position: relative;
        margin-bottom: 25px;
        padding-left: 20px;
    }

    .timeline-marker {
        position: absolute;
        left: -26px; /* Align dot to center of line */
        top: 0;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: #d70018; /* Red */
        border: 2px solid #fff;
        box-shadow: 0 0 0 2px #d70018;
    }

    .timeline-item:first-child .timeline-marker {
        background: #28a745; /* Green for latest status */
        box-shadow: 0 0 0 2px #28a745;
    }

    .timeline-content h6 {
        font-size: 15px;
    }
</style>

@section Scripts {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "3000"
        };

        $(document).ready(function () {
            var successMsg = '@TempData["Success"]';
            var errorMsg = '@TempData["Error"]';

            if (successMsg) {
                toastr.success(successMsg, 'Success');
            }
            if (errorMsg) {
                toastr.error(errorMsg, 'Error');
            }
        });
    </script>
}